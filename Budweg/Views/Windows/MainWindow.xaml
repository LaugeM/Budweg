<Window x:Class="Budweg.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Budweg.Views.Windows"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid x:Name="panelHeader" VerticalAlignment="Top" Height="50" Background="Green" MouseDown="panelHeader_MouseDown">
            
        </Grid>

        <Grid x:Name="sidePanel" HorizontalAlignment="Left" Width="150" Background="Green">
            <StackPanel>
                <Grid Height="50"  Background="White">
                    <Button x:Name="sidePanelButton"
                            HorizontalAlignment="Right"
                            Height="20"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="sidePanelButton_Click">
                        <Image Source="/icons/menu.png"/>
                    </Button>
                </Grid>
                <ListView BorderBrush="Transparent" Background="Transparent" Foreground="White">
                    <ListViewItem x:Name="homeListViewItem" Height="30">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/icons/home.png" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Margin="15, 0, 0, 0" Text="Hjem" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="registerListViewItem" Height="30">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/icons/add.png"  Height="20" VerticalAlignment="Center"/>
                            <TextBlock Margin="15, 0, 0, 0" Text="Registrer kaliber" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="overviewListViewItem" Height="30">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/icons/list.png" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Margin="15, 0, 0, 0" Text="Kaliberoversigt" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListViewItem>

                </ListView>
            </StackPanel>

        </Grid>
        <!--<Frame x:Name="Main" Margin="0,0,0,0" Grid.Row="1" Grid.Column="1"/>-->
    </Grid>
</Window>
