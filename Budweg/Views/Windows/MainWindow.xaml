<Window x:Class="Budweg.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Budweg.Views.Windows"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="9*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="32*" />
            <RowDefinition Height="185*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0" Grid.Row="1">
            <Button x:Name="RegCaliperButton" Margin="0,10,0,0" Click="RegCaliperButton_Click">
                <TextBlock TextWrapping="Wrap">Registrer kaliber</TextBlock>
            </Button>
            <Button x:Name="CaliperOverviewButton" Margin="0,10,0,0" Click="CaliperOverviewButton_Click">
                <TextBlock TextWrapping="Wrap">Kaliber oversigt</TextBlock>
            </Button>
        </StackPanel>
        <Frame x:Name="Main" Margin="0,0,0,0" Grid.Row="1" Grid.Column="1"/>
    </Grid>
</Window>
