<Page
    x:Class="Budweg.Views.Pages.FrontPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Budweg.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="FrontPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">


    <Grid x:Name="BG" Margin="70,0,0,0">

        <Grid.Background>

            <ImageBrush x:Name="img_bg"
        ImageSource="/icons/img_background.jpg"
        Stretch="Fill"/>

        </Grid.Background>

    </Grid>
</Page>
