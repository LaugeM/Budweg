<Page
    x:Class="Budweg.Views.Pages.FrontPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Budweg.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="FrontPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">


    <Grid Background="Green" Margin="0,0,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="32*" />
            <RowDefinition Height="185*" />
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center">
        </StackPanel>
        <TextBlock TextWrapping="Wrap" Text="BUDWEG" VerticalAlignment="Center" TextAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>
</Page>
