<Page
    x:Class="Budweg.Views.Pages.CaliperListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Budweg.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CaliperListPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="100" />
        </Grid.ColumnDefinitions>

        <ListBox
            x:Name="ExpenseListBox"
            Grid.Column="0"
            Margin="0,10,0,10"
            ItemsSource="{Binding EntityVMOC}"
            SelectedItem="{Binding SelectedEntityVM, UpdateSourceTrigger=PropertyChanged}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4" Orientation="Horizontal">
                        <TextBox
                            Width="110"
                            Background="Transparent"
                            BorderThickness="0"
                            IsReadOnly="True"
                            Text="{Binding StampNumber}" />
                        <TextBox
                            Width="80"
                            Margin="8,0,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            IsReadOnly="True"
                            Text="{Binding Manufacturer}" />
                        <TextBox
                            Margin="8,0,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            IsReadOnly="True"
                            Text="{Binding ModelNumber}" />
                        <TextBox
                            Margin="8,0,0,0"
                            Width="40"
                            Background="Transparent"
                            BorderThickness="0"
                            IsReadOnly="True"
                            Text="{Binding TimesRenovated}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Column="1" Orientation="Vertical">
            <Button
                Height="auto"
                Margin="0,10,0,10"
                Content="Rediger" />
            <Button
                Height="auto"
                Margin="0,10,0,10"
                Content="Slet" />
        </StackPanel>
    </Grid>
</Page>
