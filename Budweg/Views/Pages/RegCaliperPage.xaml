<Page
    x:Class="Budweg.Views.Pages.RegCaliperPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Budweg.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="RegCaliperPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="162" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Height="162"
            Padding="8"
            VerticalAlignment="Top"
            Background="#00AC58">
            <StackPanel>
                <TextBlock
                    Margin="0,30,0,0"
                    HorizontalAlignment="Center"
                    FontSize="50"
                    Foreground="White"
                    Text="BUDWEG" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Margin="0,10,0,10"
            Padding="8"
            VerticalAlignment="Top"
            Background="#00AC58">
            <Border.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="White" />
                </Style>
                <Style TargetType="Button">
                    <Setter Property="Foreground" Value="White" />
                </Style>
            </Border.Resources>
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Text="Stempelnummer" />
                    <TextBox
                        x:Name="StampNumberTextBox"
                        Width="120"
                        AcceptsReturn="True"
                        Text="{Binding CurrentEntity.StampNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Text="Producent" />
                    <TextBox
                        x:Name="manufacturerTextBox"
                        Width="120"
                        AcceptsReturn="True"
                        Text="{Binding CurrentEntity.Manufacturer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Text="Godkendelse" />
                    <ComboBox
                        x:Name="approvalComboBox"
                        Width="150"
                        Height="21"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left"
                        Background="White"
                        BorderBrush="DarkGray"
                        DisplayMemberPath="Value"
                        ItemsSource="{Binding ApprovedOptions}"
                        SelectedValue="{Binding CurrentEntity.Approval, Mode=TwoWay}"
                        SelectedValuePath="Key"
                        Style="{StaticResource {x:Static ToolBar.ComboBoxStyleKey}}" />

                </StackPanel>

                <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Text="Modelnummer" />
                    <TextBox
                        x:Name="modelNumberTextBox"
                        Width="100"
                        AcceptsReturn="True"
                        Text="{Binding CurrentEntity.ModelNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" Orientation="Vertical">
                    <Button
                        x:Name="AddButton"
                        Width="90"
                        Margin="0,0,0,5"
                        Command="{Binding Path=AddCaliperCommand}"
                        CommandParameter="{Binding}"
                        Content="Registrer kaliber" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
